{
  "manifest_version": 3,
  "name": "Knox Portal Obfuscator",
  "version": "1.0.0",
  "description": "Masks sensitive data (license keys, IMEIs, serials, emails, MACs) on the Samsung Knox portal for safe screen sharing. Click the toolbar icon to pause/resume.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["*://*.samsungknox.com/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Knox Obfuscator — click to pause/resume",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://*.samsungknox.com/*"],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "knox-obfuscator@mattintech.github.io",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
